<UserControl x:Class="Shoes.Views.TovarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Shoes.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{Binding DiscountFon}" Padding="10" Margin="10" BorderThickness="1" BorderBrush="#00FA9A">

        <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Image Source="{Binding DisplayedImage}" HorizontalAlignment="Left"  Width="100" Height="100" Grid.Column="0"/>
        <StackPanel HorizontalAlignment="Left" Grid.Column="1" Margin="15">
            <TextBlock Text="{Binding Name_Category}"  FontWeight="Bold" FontSize="18"/>
                <TextBlock Text="{Binding TovarDesc, StringFormat={}Описание товара: {0}}" FontSize="16"/>
                <TextBlock Text="{Binding Manufactrurer.ManufacturerName, StringFormat={}Производитель: {0}}" FontSize="16"/>
                <TextBlock Text="{Binding Supplier.SupplierName, StringFormat={}Поставщик: {0}}" FontSize="16"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Цена: " FontSize="16"/>

                    <TextBlock Name="OldPriceText" Text="{Binding TovarCost, StringFormat={}{0} ₽}" FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="TextDecorations" Value="{x:Null}"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                        <Setter Property="Foreground" Value="Red"/>
                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding FinalPrice, StringFormat={} → {0} ₽}" FontSize="16" Foreground="Black" Margin="5,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="{Binding TovarUnit, StringFormat={}Единица измерения: {0}}"  FontSize="16"/>
                <TextBlock Text="{Binding TovarCount, StringFormat={}Количество на складе: {0}}" Foreground="{Binding ItemBackgroundColor}" FontSize="16"/>
        </StackPanel>
            <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="16" VerticalAlignment="Center" Text="{Binding TovarCurrentSale, StringFormat={}Действующая скидка: {0} %}"/>

    </Grid>
    </Border>
</UserControl>
