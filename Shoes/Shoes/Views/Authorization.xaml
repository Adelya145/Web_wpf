<Window x:Class="Shoes.Views.Authorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes.Views"
        mc:Ignorable="d"
        Title="Авторизация" Icon="/Resources/Icon.ico"  MinHeight="500" MinWidth="800"  Height="500" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#7FFF00">
            <Image Source="/Resources/Icon.png" HorizontalAlignment="Left" Margin="5"></Image>
            <Button x:Name="enter_guest" Content="Войти как гость" Padding="10" Click="enter_guest_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="#00FA9A" FontSize="18" Margin="5"/>
            <TextBlock Text="ООО Обувь" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"></TextBlock>
        </Grid>
        <TextBlock Text="Авторизация" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
        <Grid Grid.Row="2" Margin="150 50">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Логин:" VerticalAlignment="Bottom" Grid.Row="0" FontSize="23" Margin="0,0,0,10"/>
            <TextBox FontSize ="18" Grid.Row="1" Margin="0,0,0,10" x:Name="login_tb" MaxHeight="50"/>
            <TextBlock Text="Пароль:" VerticalAlignment="Bottom" Grid.Row="2" FontSize="23" Margin="0,0,0,10"/>
            <PasswordBox FontSize ="18" Grid.Row="3" Margin="0,0,0,10" x:Name="pass_pb" MaxHeight="50"/>
            <Button x:Name="log_btn" Grid.Row="4" Content="Войти" Click="log_btn_Click" MaxHeight="50" Margin="100 0" FontSize="20" Background="#00FA9A"/>
        
        </Grid>
            
    </Grid>
</Window>
