<UserControl x:Class="Shoes.Views.OrderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Shoes.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Padding="10" Margin="10" BorderThickness="1" BorderBrush="Black">
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel HorizontalAlignment="Left" Grid.Column="0" Margin="15">
                <TextBlock Text="{Binding OrderId, StringFormat={} Артикул заказа: {0}}" FontWeight="Bold" FontSize="18"/>
                <TextBlock Text="{Binding OrderStatus, StringFormat={}Статус заказа: {0}}" FontSize="16"/>
                <TextBlock Text="{Binding PickUpFullAddress, StringFormat={}Адрес пункта выдачи: {0}}" FontSize="16"/>
                <TextBlock Text="{Binding OrderDate, StringFormat= 'Дата заказа: {0:dd.MM.yyyy}'}" FontSize="16"/>
            </StackPanel>
            <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="16" VerticalAlignment="Center" Text="{Binding OrderDateDelivery, StringFormat= 'Дата доставки: {0:dd.MM.yyyy}'}"/>

        </Grid>
    </Border>
</UserControl>
