<Window x:Class="Shoes.Views.AddRedactOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes.Views"
        mc:Ignorable="d"
        Title="AddRedactOrder" Icon="/Resources/Icon.ico" WindowState="Maximized" Height="700" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#7FFF00">
            <Image Source="/Resources/Icon.png" Margin="5" HorizontalAlignment="Left"></Image>
            <TextBlock Text="ООО Обувь" HorizontalAlignment="Center" FontSize="20" VerticalAlignment="Center"></TextBlock>
            <Button x:Name="back_btn" HorizontalAlignment="Right" Background="#00FA9A" FontSize="18" Margin="10" Padding="15 10" VerticalAlignment="Center" Content="Назад" Click="back_btn_Click"></Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="20" Grid.Column="0" Orientation="Vertical">
                <TextBlock FontSize="18">Артикул</TextBlock>
                <TextBox Padding="5" Margin="5" FontSize="18" IsEnabled="False" x:Name="article"></TextBox>

                <TextBlock FontSize="18">Дата заказа</TextBlock>
                <DatePicker Padding="5" Margin="5" FontSize="18" x:Name="date"></DatePicker>

                <TextBlock FontSize="18">Дата доставки</TextBlock>
                <DatePicker Padding="5" Margin="5" FontSize="18" x:Name="date_delivery"></DatePicker>

                <TextBlock FontSize="18">Пункт выдачи</TextBlock>
                <ComboBox x:Name="cbPickup" 
                          FontSize="18"
                          Margin="5"
                          DisplayMemberPath="PickUpFullAddress"
                          SelectedValuePath="PickUpPointId"/>

                <TextBlock FontSize="18">Заказчик</TextBlock>
                <ComboBox x:Name="cbUser"
                          Margin="5"
                          FontSize="18"
                          DisplayMemberPath="SNL"
                          SelectedValuePath="UserId"/>

                <TextBlock FontSize="18">Код для получения</TextBlock>
                <TextBox Padding="5" Margin="5" IsEnabled="False" FontSize="18" x:Name="code"></TextBox>

                <TextBlock FontSize="18">Статус</TextBlock>
                <ComboBox Padding="5" Margin="5" FontSize="18" x:Name="status"></ComboBox>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="1" Orientation="Vertical">
                <TextBlock FontSize="18" FontWeight="Bold" Margin="0 0 0 10">Товары в заказе</TextBlock>

                <TextBlock FontSize="16">Выберите товар</TextBlock>
                <ComboBox x:Name="cbProducts"
                          FontSize="16"
                          Margin="5"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="TovarArticle"
                          SelectionChanged="cbProducts_SelectionChanged"/>

                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtProductCount" 
                             Grid.Column="0"
                             FontSize="16" 
                             Padding="5"
                             Text="1" PreviewTextInput="txtProductCount_PreviewTextInput"/>
                    <Button x:Name="btnAddProduct" 
                            Grid.Column="1"
                            Content="Добавить" 
                            FontSize="16"
                            Background="#00FA9A"
                            Padding="15 5"
                            Margin="10 0 0 0"
                            Click="btnAddProduct_Click"/>
                </Grid>

                <TextBlock FontSize="16" Margin="0 20 0 5">Состав заказа:</TextBlock>
                <ListView x:Name="lvOrderItems" 
                          FontSize="14"
                          Height="200"
                          Margin="5"
                          SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Артикул" Width="80" DisplayMemberBinding="{Binding TovarArticle}"/>
                            <GridViewColumn Header="Наименование" Width="150" DisplayMemberBinding="{Binding TovarName}"/>
                            <GridViewColumn Header="Кол-во" Width="60" DisplayMemberBinding="{Binding Count}"/>
                            <GridViewColumn Header="Действия" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Удалить" 
                                                Background="#FF6347" 
                                                Foreground="White"
                                                Padding="5 2"
                                                Click="RemoveItem_Click"
                                                Tag="{Binding}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button FontSize="18" 
                        Background="#00FA9A" 
                        Padding="5" 
                        Margin="20 20 20 0" 
                        x:Name="SaveOrder" 
                        Click="SaveOrder_Click">Сохранить</Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>